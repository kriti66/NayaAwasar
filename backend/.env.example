# Copy to .env in this folder and replace placeholders. Never commit .env.
# No spaces around = unless the value is quoted.

PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/your_database_name
JWT_SECRET=your_jwt_secret_use_a_long_random_string

# Google OAuth (Web client from Google Cloud Console)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# App URLs
FRONTEND_URL=http://localhost:5173

# FastAPI recommendation-service (repo /recommendation-service). Default local port often 8001.
RECOMMENDATION_SERVICE_URL=http://127.0.0.1:8001

# Optional: request timeout in ms (default 90000)
# RECOMMENDATION_SERVICE_TIMEOUT_MS=90000

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Email (SMTP)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
EMAIL_USER=your_email@example.com
EMAIL_PASS=your_app_password
EMAIL_FROM=your_email@example.com

# Zego (video / RTC if used)
ZEGO_APP_ID=your_zego_app_id
ZEGO_SERVER_SECRET=your_zego_server_secret
